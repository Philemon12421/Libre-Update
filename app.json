{
  "expo": {
    "name": "Libre",
    "slug": "libre-archival-node",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2563eb",
      "androidMode": "default",
      "androidCollapsedTitle": "Libre"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.philemon.libre"
    },
    "android": {
      "package": "com.philemon.libre",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Libre to access your photos.",
          "savePhotosPermission": "Allow Libre to save files to your library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8ca44671-1f06-445e-bc61-e083d5a41bec"
      }
    }
  }
}
